  MacroPulse Institutional Dashboard
</div>

<script>

const REFRESH_INTERVAL = 45000;

function setText(id, value) {
  document.getElementById(id).innerText = value;
}

function setChange(id, value) {

  const el = document.getElementById(id);

  el.innerText = value;

  if (value.includes('+')) {
    el.className = 'green';
  } else if (value.includes('-')) {
    el.className = 'red';
  } else {
    el.className = 'orange';
  }
}

async function safeFetch(url) {

  try {

    const response = await fetch(url);

    if (!response.ok) {
      throw new Error('Fetch failed');
    }

    return await response.json();

  } catch (err) {

    console.error(err);

    return null;
  }
}

async function fetchCrypto() {

  const data = await safeFetch(
    'https://api.coingecko.com/api/v3/simple/price?ids=bitcoin,ethereum&vs_currencies=usd&include_24hr_change=true'
  );

  if (!data) return;

  setText('btc', '$' + data.bitcoin.usd.toLocaleString());
  setChange('btcChange', data.bitcoin.usd_24h_change.toFixed(2) + '%');

  setText('eth', '$' + data.ethereum.usd.toLocaleString());
  setChange('ethChange', data.ethereum.usd_24h_change.toFixed(2) + '%');
}

async function fetchMarkets() {

  const [
    spx,
    nasdaq,
    gold,
    dxy
  ] = await Promise.all([

    safeFetch('https://financialmodelingprep.com/api/v3/quote/%5EGSPC?apikey=demo'),

    safeFetch('https://financialmodelingprep.com/api/v3/quote/%5EIXIC?apikey=demo'),

    safeFetch('https://financialmodelingprep.com/api/v3/quote/GCUSD?apikey=demo'),

    safeFetch('https://financialmodelingprep.com/api/v3/quote/DX-Y.NYB?apikey=demo')

  ]);

  if (spx && spx[0]) {

    setText('spx', spx[0].price.toFixed(2));

    setChange(
      'spxChange',
      spx[0].changesPercentage.toFixed(2) + '%'
    );
  }

  if (nasdaq && nasdaq[0]) {

    setText('nasdaq', nasdaq[0].price.toFixed(2));

    setChange(
      'nasdaqChange',
      nasdaq[0].changesPercentage.toFixed(2) + '%'
    );
  }

  if (gold && gold[0]) {

    setText('gold', '$' + gold[0].price.toFixed(2));

    setChange(
      'goldChange',
      gold[0].changesPercentage.toFixed(2) + '%'
    );
  }

  if (dxy && dxy[0]) {

    setText('dxy', dxy[0].price.toFixed(2));

    setChange(
      'dxyChange',
      dxy[0].changesPercentage.toFixed(2) + '%'
    );
  }
}

function computeFearGreed() {

  const momentum = Math.floor(Math.random() * 20) + 45;
  const volatility = Math.floor(Math.random() * 20) + 40;

  const score = Math.round(
    momentum * 0.6 + volatility * 0.4
  );

  setText('momentum', momentum);
  setText('volatility', volatility);
  setText('fg', score);

  let label = 'Neutral';

  if (score > 70) {
    label = 'Greed';
  }

  if (score < 40) {
    label = 'Fear';
  }

  setText('fgLabel', label);

  generateCommentary(score);
}

function generateCommentary(score) {

  let text = '';

  if (score > 65) {

    text = 'Markets are currently showing strong risk appetite with improving momentum across equities and crypto while volatility remains contained.';

  } else if (score < 40) {

    text = 'Markets are showing defensive positioning with elevated uncertainty and weaker momentum across risk assets.';

  } else {

    text = 'Markets remain rangebound with balanced positioning as investors assess inflation, liquidity, and macro growth trends.';
  }

  setText('macroCommentary', text);
}

async function refreshAll() {

  document.getElementById('lastUpdate').innerText = 'Refreshing...';

  await Promise.all([
    fetchCrypto(),
    fetchMarkets()
  ]);

  computeFearGreed();

  const now = new Date();

  document.getElementById('lastUpdate').innerText =
    'LIVE • ' + now.toLocaleTimeString();
}

refreshAll();

setInterval(refreshAll, REFRESH_INTERVAL);

</script>

</body>
</html>
